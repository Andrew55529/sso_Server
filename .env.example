# SSO Server — Environment Variables
# Copy this file to .env and adjust the values.

# HTTP server listen address
HTTP_ADDR=:8080

# SQLite database path (inside container: /app/data/sso.db)
DB_PATH=./data/sso.db

# ── JWT Secrets (change these before production!) ──────────────────────────
ACCESS_SECRET=change-me-access-secret
REFRESH_SECRET=change-me-refresh-secret
ID_SECRET=change-me-id-secret

# ── Token TTLs ─────────────────────────────────────────────────────────────
# Access / ID token lifetime in minutes (default 15)
ACCESS_TTL_MINUTES=15
ID_TTL_MINUTES=15
# Refresh token lifetime in days (default 30)
REFRESH_TTL_DAYS=30

# ── Admin UI credentials ───────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD=admin
